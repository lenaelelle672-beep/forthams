reject_rationale_322", "label": "rejectionReason of exactly 500 characters must be accepted.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L322"}, {"id": "test_work_order_reject_rationale_337", "label": "A 400 validation failure must leave the order status unchanged.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L337"}, {"id": "test_work_order_reject_rationale_355", "label": "Rejecting from states other than APPROVING_LEVEL_1/2 must fail.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L355"}, {"id": "test_work_order_reject_rationale_363", "label": "PENDING \u2192 REJECTED is not a valid transition; expect HTTP 409.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L363"}, {"id": "test_work_order_reject_rationale_379", "label": "After a 409 rejection attempt, the order must remain PENDING.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L379"}, {"id": "test_work_order_reject_rationale_394", "label": "REJECTED is a terminal state; rejecting again must return HTTP 409.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L394"}, {"id": "test_work_order_reject_rationale_409", "label": "APPROVED is a terminal state; rejecting must return HTTP 409.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L409"}, {"id": "test_work_order_reject_rationale_424", "label": "CANCELLED is a terminal state; rejecting must return HTTP 409.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L424"}, {"id": "test_work_order_reject_rationale_447", "label": "Verify that stale version values cause HTTP 409 Conflict.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L447"}, {"id": "test_work_order_reject_rationale_455", "label": "Sending an outdated version must result in HTTP 409.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L455"}, {"id": "test_work_order_reject_rationale_473", "label": "A failed optimistic-lock reject must not change the order status.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L473"}, {"id": "test_work_order_reject_rationale_492", "label": "Sending the current version must allow the rejection to proceed.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L492"}, {"id": "test_work_order_reject_rationale_511", "label": "Verify that approval records are correctly persisted on rejection.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L511"}, {"id": "test_work_order_reject_rationale_519", "label": "The approval record must capture the operator who rejected.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L519"}, {"id": "test_work_order_reject_rationale_539", "label": "The approval record must contain a valid ISO-8601 timestamp.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L539"}, {"id": "test_work_order_reject_rationale_562", "label": "The approval record comment must exactly match the rejectionReason.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L562"}, {"id": "test_work_order_reject_rationale_584", "label": "Edge-case scenarios for the reject endpoint.", "file_type": "rationale", "source_file": "tests/api/test_work_order_reject.py", "source_location": "L584"}, {"id": "test_work_order_reject_rationale_591", "label": "Rejecting a non-existent order must return HTTP 404.", "file_type": "ratio