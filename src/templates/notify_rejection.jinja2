{#**
 * 通知模板：工单审批驳回通知
 * SWARM-2025-Q2-P0-003 Iteration 6
 * 
 * 触发时机: 工单状态从 PENDING_APPROVAL 变更为 REJECTED
 * 通知渠道: 邮件 + 站内信
 *#}
{% extends "base_notification.jinja2" %}

{% block subject %}工单审批被驳回 - {{ workorder_id }}{% endblock %}

{% block content %}
<div class="notification-content">
    <h2>⚠️ 工单审批驳回通知</h2>
    
    <div class="info-section">
        <p><strong>工单编号:</strong> {{ workorder_id }}</p>
        <p><strong>工单标题:</strong> {{ workorder_title }}</p>
        <p><strong>审批人:</strong> {{ approver_name }}</p>
        <p><strong>审批时间:</strong> {{ timestamp }}</p>
    </div>
    
    <div class="rejection-reason">
        <h3>驳回原因</h3>
        <div class="reason-box">
            {{ reason }}
        </div>
    </div>
    
    {% if comment %}
    <div class="comment-section">
        <h3>审批意见</h3>
        <p>{{ comment }}</p>
    </div>
    {% endif %}
    
    <div class="action-section">
        <p>请根据驳回原因修改工单后重新提交审批。</p>
        <a href="{{ workorder_detail_url }}" class="action-button">查看工单详情</a>
    </div>
    
    <div class="footer">
        <p>本通知由资产管理系统自动发送，请勿回复。</p>
        <p>如有问题，请联系系统管理员。</p>
    </div>
</div>
{% endblock %}

{% block email_style %}
<style>
    .notification-content {
        font-family: Arial, sans-serif;
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
        background-color: #ffffff;
    }
    .notification-content h2 {
        color: #d32f2f;
        border-bottom: 2px solid #d32f2f;
        padding-bottom: 10px;
    }
    .info-section {
        background-color: #f5f5f5;
        padding: 15px;
        border-radius: 5px;
        margin: 20px 0;
    }
    .rejection-reason {
        margin: 20px 0;
    }
    .rejection-reason h3 {
        color: #d32f2f;
    }
    .reason-box {
        background-color: #ffebee;
        border-left: 4px solid #d32f2f;
        padding: 15px;
        margin: 10px 0;
        white-space: pre-wrap;
        word-wrap: break-word;
    }
    .comment-section {
        margin: 20px 0;
        padding: 15px;
        background-color: #e3f2fd;
        border-radius: 5px;
    }
    .action-section {
        text-align: center;
        margin: 30px 0;
    }
    .action-button {
        display: inline-block;
        padding: 12px 30px;
        background-color: #1976d2;
        color: #ffffff;
        text-decoration: none;
        border-radius: 5px;
        font-weight: bold;
    }
    .action-button:hover {
        background-color: #1565c0;
    }
    .footer {
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #e0e0e0;
        color: #757575;
        font-size: 12px;
    }
</style>
{% endblock %}