{#}
{# Notification template for work order approval #}
{# Variable: workorder_id, action, approver_id, approver_name, reason, timestamp, applicant_name, workorder_title #}
{#
    Action types: APPROVED, REJECTED, TRANSFERRED
    This template is used for both email and in-app notification
#}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>工单审批通知</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }
        .header {
            background-color: #4CAF50;
            color: white;
            padding: 20px;
            text-align: center;
            border-radius: 8px 8px 0 0;
        }
        .content {
            background-color: #f9f9f9;
            padding: 20px;
            border: 1px solid #ddd;
        }
        .info-row {
            margin: 10px 0;
            padding: 10px;
            background-color: white;
            border-left: 4px solid #4CAF50;
        }
        .label {
            font-weight: bold;
            color: #555;
        }
        .action-approved {
            color: #4CAF50;
        }
        .action-rejected {
            color: #f44336;
        }
        .action-transferred {
            color: #2196F3;
        }
        .reason-box {
            background-color: #fff3cd;
            border: 1px solid #ffc107;
            padding: 15px;
            margin: 15px 0;
            border-radius: 4px;
        }
        .footer {
            text-align: center;
            padding: 15px;
            color: #888;
            font-size: 12px;
            border-top: 1px solid #ddd;
        }
        .timestamp {
            color: #999;
            font-size: 12px;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>✅ 工单审批通过通知</h1>
    </div>
    
    <div class="content">
        <p>您好，<strong>{{ applicant_name }}</strong>：</p>
        
        <p>您提交的工单已通过审批，请知悉。</p>
        
        <div class="info-row">
            <div><span class="label">工单编号：</span> #{{ workorder_id }}</div>
        </div>
        
        <div class="info-row">
            <div><span class="label">工单标题：</span> {{ workorder_title }}</div>
        </div>
        
        <div class="info-row">
            <div><span class="label">审批动作：</span> 
                <span class="action-approved">✅ 已通过</span>
            </div>
        </div>
        
        <div class="info-row">
            <div><span class="label">审批人：</span> {{ approver_name }} (ID: {{ approver_id }})</div>
        </div>
        
        {% if comment %}
        <div class="info-row">
            <div><span class="label">审批意见：</span> {{ comment }}</div>
        </div>
        {% endif %}
        
        <div class="info-row">
            <div><span class="label">审批时间：</span> {{ timestamp }}</div>
        </div>
        
        <p style="margin-top: 20px;">
            如有疑问，请联系审批人或系统管理员。
        </p>
    </div>
    
    <div class="footer">
        <p>本邮件由资产管理系统自动发送，请勿直接回复。</p>
        <p class="timestamp">发送时间：{{ timestamp }}</p>
    </div>
</body>
</html>