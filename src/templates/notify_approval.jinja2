{#**
 * 审批通知模板 - 工单审批流程
 * 
 * 支持的通知类型:
 * - APPROVED: 审批通过
 * - REJECTED: 审批驳回
 * - TRANSFERRED: 审批转交
 *#}

{% extends "base_notification.jinja2" %}

{% block subject %}
{% if action == "APPROVED" %}
【审批通过】工单 #{{ workorder_id }} 已审批通过
{% elif action == "REJECTED" %}
【审批驳回】工单 #{{ workorder_id }} 被驳回
{% elif action == "TRANSFERRED" %}
【审批转交】工单 #{{ workorder_id }} 已转交
{% endif %}
{% endblock %}

{% block content %}
<div class="approval-content">
    <div class="header">
        <h2>工单审批通知</h2>
    </div>
    
    <div class="info-card">
        <table class="info-table">
            <tr>
                <td class="label">工单编号：</td>
                <td class="value"><strong>#{{ workorder_id }}</strong></td>
            </tr>
            <tr>
                <td class="label">审批动作：</td>
                <td class="value">
                    {% if action == "APPROVED" %}
                    <span class="badge badge-success">通过</span>
                    {% elif action == "REJECTED" %}
                    <span class="badge badge-danger">驳回</span>
                    {% elif action == "TRANSFERRED" %}
                    <span class="badge badge-warning">转交</span>
                    {% endif %}
                </td>
            </tr>
            <tr>
                <td class="label">审批人：</td>
                <td class="value">{{ approver_name | default('系统') }}</td>
            </tr>
            <tr>
                <td class="label">审批时间：</td>
                <td class="value">{{ timestamp }}</td>
            </tr>
            {% if comment %}
            <tr>
                <td class="label">审批意见：</td>
                <td class="value">{{ comment }}</td>
            </tr>
            {% endif %}
            {% if reason %}
            <tr>
                <td class="label">驳回原因：</td>
                <td class="value reason">{{ reason }}</td>
            </tr>
            {% endif %}
            {% if transferred_to %}
            <tr>
                <td class="label">转交至：</td>
                <td class="value">{{ transferred_to }}</td>
            </tr>
            {% endif %}
        </table>
    </div>
    
    {% if action == "REJECTED" %}
    <div class="alert alert-warning">
        <strong>温馨提示：</strong>您的工单已被驳回，请根据驳回原因修改后重新提交。
    </div>
    {% elif action == "APPROVED" %}
    <div class="alert alert-success">
        <strong>恭喜：</strong>您的工单已审批通过，相关流程将继续执行。
    </div>
    {% elif action == "TRANSFERRED" %}
    <div class="alert alert-info">
        <strong>通知：</strong>您的工单已转交给其他审批人处理。
    </div>
    {% endif %}
    
    <div class="action-section">
        <a href="{{ workorder_detail_url }}" class="btn btn-primary">查看工单详情</a>
    </div>
</div>
{% endblock %}

{% block footer_text %}
本邮件由系统自动发送，请勿直接回复。
如有问题，请联系管理员。
{% endblock %}