+
+## 4. 验收测试基准 (ATB)
+
+### 4.1 单元测试 (TenantContextTest.java)
+
+```java
+// ATB-001: ThreadLocal 存取值验证
+@Test
+public void testSetAndGet() {
+    Long tenantId = 1001L;
+    TenantContext.setTenantId(tenantId);
+    assertEquals(tenantId, TenantContext.getTenantId());  // 物理期待: 值相等
+    TenantContext.clear(); // 清理
+    assertNull(TenantContext.getTenantId());              // 物理期待: 已清空
+}
+
+// ATB-002: 线程隔离验证
+@Test
+public void testThreadIsolation() throws InterruptedException {
+    Long mainTenant = 1001L;
+    Long childTenant = 1002L;
+    TenantContext.setTenantId(mainTenant);
+    
+    Thread child = new Thread(() -> {
+        assertNull(TenantContext.getTenantId());          // 物理期待: 子线程无值
+        TenantContext.setTenantId(childTenant);
+        assertEquals(childTenant, TenantContext.getTenantId());
+    });
+    child.start();
+    child.join();
+    
+    assertEquals(mainTenant, TenantContext.getTenantId()); // 物理期待: 主线程未受影响
+}
+
+// ATB-003: 空上下文检测
+@Test(expected = TenantContextException.class)
+public void testGetWithoutSet() {
+    TenantContext.getTenantId();  // 物理期待: 抛出 TenantContextException
+}
+```
+
+### 4.2 单元测试 (TenantIsolationAspectTest.java)
+
+```java
+// ATB-004: 缺少租户上下文时拒绝访问
+@Test
+public void testMissingTenantContextBlocksAccess() {
+    TenantContext.clear();  // 确保无上下文
+    whenJoinPoint.getMethod().getAnnotation(RequireTenant.class)
+        .thenReturn(createAnnotation());
+    
+    aspect.checkTenantContext(joinPoint);  // 物理期待: 抛出 SecurityException(403)
+}
+
+// ATB-005: 有效租户上下文允许通过
+@Test
+public void testValidTenantContextAllowsAccess() {
+    TenantContext.setTenantId(1001L);
+    whenJoinPoint.getMethod().getAnnotation(RequireTenant.class)
+        .thenReturn(createAnnotation());
+    
+    aspect.checkTenantContext(joinPoint);  // 物理期待: 正常执行无异常
+}
+```
+
+### 4.3 集成测试 (TenantIsolationIT.java)
+
+```java
+// ATB-006: 租户 A 无法访问租户 B 的资产
+@Test
+public void testTenantDataIsolation() {
+    // 租户 A 创建资产
+    String tokenA = generateToken(1001L, "tenantA");
+    Long assetIdA = createAsset(tokenA, "Asset-A-001");
+    
+    // 租户 B 创建资产
+    String tokenB = generateToken(1002L, "tenantB");
+    Long assetIdB = createAsset(tokenB, "Asset-B-001");
+    
+    // 租户 A 尝试访问租户 B 的资产
+    ResponseEntity<Asset> response = restTemplate.exchange(
+        "/api/assets/{id}",
+        HttpMethod.GET,
+        new HttpEntity<>(authHeader(tokenA)),
+        Asset.class,
+        assetIdB  // 物理期待: 404 或 403
+    );
+    
+    assertTrue(
+        response.getStatusCode() == HttpStatus.NOT_FOUND || 
+        response.getStatusCode() == HttpStatus.FORBIDDEN
+    );
+}
+
+// ATB-007: SQL 注入防护验证
+@Test
+public void testSqlInjectionBlocked() {
+    String maliciousTenantId = "1001; DROP TABLE assets;--";
+    String token = generateToken(1001L, "tenantA");
+    
+    assertThatThrownBy(() -> 
+        restTemplate.exchange(
+            "/api/assets",
+            HttpMethod.GET,
+            new HttpEntity<>(authHeader(token)),
+            Asset[].class
+        )
+    ).satisfies(e -> {
+        // 物理期待: 参数绑定机制阻止注入，而非拼接
+        assertThat(e.getMessage()).doesNotContain("DROP TABLE");
+    });
+}
+
+// ATB-008: JWT 篡改检测
+@Test
+public void testTamperedJwtRejected() {
+    String tamperedToken = jwtToken.replaceAll("tenant_id.*?(,|\})", 
+        "\"tenant_id\": 9999,");
+    
+    restTemplate.exchange(
+        "/api/assets",
+        HttpMethod.GET,
+        new HttpEntity<>(authHeader(tamperedToken)),
+        Asset[].class
+    );  // 物理期待: JwtAuthenticationFilter 层拒绝，401
+    
+    verify(assetService, never()).listAssets(any());
+}
+```
+
+### 4.4 安全渗透测试用例
+
+```bash
+# ATB-009: Postman/Playwright 自动化渗透
+# 文件: src/test/resources/tenant_isolation.robot
+
+*** Test Cases ***
+Tenant Isolation Violation Attempt
+    # 尝试通过 X-Tenant-Id header 绕过
+    Given Request with header "X-Tenant-Id: 9999"
+    When GET /api/assets/123
+    Then Response status should be 403
+    And Response body should NOT contain tenant information
+
+SQL Injection Via Tenant Parameter
+    # 模拟恶意 tenant_id 参数
+    Given Request with JWT containing "tenant_id": "1 OR 1=1"
+    When GET /api/assets
+    Then SQL should contain parameterized query
+    And No rows should be returned without explicit tenant match
+
+Concurrent Tenant Context Leak
+    # 线程池场景验证
+    Given ExecutorService with 10 threads
+    And Each thread sets different tenant_id
+    When All threads query assets concurrently
+    Then Each result set should contain ONLY its tenant's assets
+```
