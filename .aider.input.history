+### 自动化测试代码片段示例
+
+```python
+# tests/test_tenant_isolation.py
+import pytest
+import requests
+
+BASE_URL = "[URL_REMOVED]
+
+class TestTenantIsolation:
+    
+    def test_normal_tenant_access(self, valid_jwt_tenant_100):
+        """ATB-01: 正常租户访问"""
+        response = requests.get(
+            f"{BASE_URL}/assets",
+            headers={"Authorization": f"Bearer {valid_jwt_tenant_100}"}
+        )
+        assert response.status_code == 200
+        data = response.json()
+        for asset in data.get("content", []):
+            assert asset["tenantId"] == 100, "所有资产必须属于当前租户"
+    
+    def test_cross_tenant_blocked(self, valid_jwt_tenant_100):
+        """ATB-04: 跨租户越权尝试"""
+        response = requests.get(
+            f"{BASE_URL}/assets?tenant_id=200",
+            headers={"Authorization": f"Bearer {valid_jwt_tenant_100}"}
+        )
+        assert response.status_code == 200
+        data = response.json()
+        # 即使传了 tenant_id=200，仍返回当前用户租户的数据
+        for asset in data.get("content", []):
+            assert asset["tenantId"] == 100, "越权参数必须被忽略"
+    
+    def test_sql_injection_blocked(self, valid_jwt_tenant_100):
+        """ATB-05: SQL注入防护"""
+        malicious_param = "tenant_id=1 OR 1=1"
+        response = requests.get(
+            f"{BASE_URL}/assets?{malicious_param}",
+            headers={"Authorization": f"Bearer {valid_jwt_tenant_100}"}
+        )
+        assert response.status_code == 200
+        data = response.json()
+        # 验证没有泄露其他租户数据
+        tenant_ids = {asset["tenantId"] for asset in data.get("content", [])}
+        assert tenant_ids == {100}, f"SQL注入未遂，但仍泄露多租户数据: {tenant_ids}"
+```
