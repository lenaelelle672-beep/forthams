+### 层级六：Service 层集成
+
+**目标文件**: `backend/src/main/java/com/ams/service/impl/AssetServiceImpl.java`
+
+```java
+package com.ams.service.impl;
+
+import com.ams.context.TenantContextHolder;
+import com.ams.entity.Asset;
+import com.ams.exception.ResourceNotFoundException;
+import com.ams.exception.TenantSecurityException;
+import com.ams.repository.AssetRepository;
+import com.ams.service.AssetService;
+import lombok.RequiredArgsConstructor;
+import org.springframework.stereotype.Service;
+import org.springframework.transaction.annotation.Transactional;
+
+import java.util.List;
+
+@Service
+@RequiredArgsConstructor
+public class AssetServiceImpl implements AssetService {
+    
+    private final AssetRepository assetRepository;
+    
+    @Override
+    public List<Asset> listAssets() {
+        Long tenantId = TenantContextHolder.getCurrentTenantId();
+        return assetRepository.findByTenantId(tenantId);
+    }
+    
+    @Override
+    public Asset getAsset(Long assetId) {
+        Long tenantId = TenantContextHolder.getCurrentTenantId();
+        return assetRepository.findByIdAndTenantId(assetId, tenantId)
+            .orElseThrow(() -> new ResourceNotFoundException("Asset", assetId));
+    }
+    
+    @Override
+    @Transactional
+    public Asset createAsset(Asset asset) {
+        Long tenantId = TenantContextHolder.getCurrentTenantId();
+        asset.setTenantId(tenantId); // 自动注入租户ID
+        return assetRepository.save(asset);
+    }
+    
+    @Override
+    @Transactional
+    public Asset updateAsset(Long assetId, Asset updateData) {
+        Long tenantId = TenantContextHolder.getCurrentTenantId();
+        Asset asset = assetRepository.findByIdAndTenantId(assetId, tenantId)
+            .orElseThrow(() -> new TenantSecurityException(
+                "TENANT_MISMATCH",
+                "无权操作其他租户的资产"
+            ));
+        
+        // 更新非租户字段
+        asset.setName(updateData.getName());
+        return assetRepository.save(asset);
+    }
+}
+```
+
