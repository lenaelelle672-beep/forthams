+### 层级五：Repository 层隔离
+
+**目标文件**: `backend/src/main/java/com/ams/repository/AssetRepository.java`
+
+```java
+package com.ams.repository;
+
+import com.ams.entity.Asset;
+import org.springframework.data.jpa.repository.JpaRepository;
+import org.springframework.data.jpa.repository.Query;
+import org.springframework.data.repository.query.Param;
+import org.springframework.stereotype.Repository;
+
+import java.util.List;
+import java.util.Optional;
+
+/**
+ * 资产仓储层
+ * 所有查询强制携带租户ID过滤
+ */
+@Repository
+public interface AssetRepository extends JpaRepository<Asset, Long> {
+    
+    /**
+     * 按租户ID查询资产列表
+     * @param tenantId 租户ID（从安全上下文注入，禁止从请求参数获取）
+     */
+    @Query("SELECT a FROM Asset a WHERE a.tenantId = :tenantId")
+    List<Asset> findByTenantId(@Param("tenantId") Long tenantId);
+    
+    /**
+     * 按ID和租户ID查询（防越权）
+     */
+    @Query("SELECT a FROM Asset a WHERE a.id = :id AND a.tenantId = :tenantId")
+    Optional<Asset> findByIdAndTenantId(@Param("id") Long id, 
+                                        @Param("tenantId") Long tenantId);
+    
+    /**
+     * 更新资产（强制租户校验）
+     */
+    @Query("UPDATE Asset a SET a.name = :name WHERE a.id = :id AND a.tenantId = :tenantId")
+    int updateByIdAndTenantId(@Param("id") Long id, 
+                              @Param("name") String name,
+                              @Param("tenantId") Long tenantId);
+}
+```
+
