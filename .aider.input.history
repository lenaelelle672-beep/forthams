+## 开发切入层级序列
+
+### 层级一：租户上下文基础设施
+
+**目标文件**: `backend/src/main/java/com/ams/context/TenantContextHolder.java`
+
+```java
+package com.ams.context;
+
+import com.ams.utils.JwtUtil;
+
+/**
+ * 租户上下文持有者
+ * ThreadLocal 线程安全隔离
+ */
+public class TenantContextHolder {
+    
+    private static final ThreadLocal<Long> TENANT_CONTEXT = new ThreadLocal<>();
+    
+    /**
+     * 从JWT Token安全上下文中提取并设置租户ID
+     * @param token JWT Token
+     * @throws TenantSecurityException 当Token无tenant_id时抛出
+     */
+    public static void setFromToken(String token) {
+        Long tenantId = JwtUtil.getTenantIdFromToken(token);
+        if (tenantId == null) {
+            throw new TenantSecurityException("MISSING_TENANT_CONTEXT", 
+                "JWT Token 必须包含 tenant_id 声明");
+        }
+        TENANT_CONTEXT.set(tenantId);
+    }
+    
+    public static Long getCurrentTenantId() {
+        return TENANT_CONTEXT.get();
+    }
+    
+    public static void clear() {
+        TENANT_CONTEXT.remove();
+    }
+}
+```
+
+**依赖项**: `JwtUtil.java` 需新增 `getTenantIdFromToken(String token)` 方法
+
+---
+
+### 层级二：JWT Token 扩展
+
+**目标文件**: `backend/src/main/java/com/ams/utils/JwtUtil.java`
+
+```java
+/**
+ * 从Token中提取租户ID
+ * @param token JWT Token
+ * @return tenant_id 或 null
+ */
+public static Long getTenantIdFromToken(String token) {
+    Claims claims = getClaimsFromToken(token);
+    Object tenantIdClaim = claims.get("tenant_id");
+    if (tenantIdClaim == null) {
+        return null;
+    }
+    if (tenantIdClaim instanceof Integer) {
+        return ((Integer) tenantIdClaim).longValue();
+    }
+    if (tenantIdClaim instanceof Long) {
+        return (Long) tenantIdClaim;
+    }
+    return Long.parseLong(tenantIdClaim.toString());
+}
+```
+
+---
+
+### 层级三：请求过滤器层
+
+**目标文件**: `backend/src/main/java/com/ams/config/JwtAuthenticationFilter.java`
+
+```java
+@Override
+protected void doFilterInternal(HttpServletRequest request, 
+                                HttpServletResponse response, 
+                                FilterChain filterChain) 
+        throws ServletException, IOException {
+    try {
+        String token = extractToken(request);
+        if (token != null) {
+            // 设置用户上下文
+            Authentication auth = jwtUtil.getAuthentication(token);
+            SecurityContextHolder.getContext().setAuthentication(auth);
+            
+            // 【新增】设置租户上下文
+            TenantContextHolder.setFromToken(token);
+        }
+        filterChain.doFilter(request, response);
+    } finally {
+        // 【必须】请求结束时清理 ThreadLocal
+        TenantContextHolder.clear();
+        SecurityContextHolder.clearContext();
+    }
+}
+```
+
+---
+
+### 层级四：AOP 强制校验切面
+
+**目标文件**: `backend/src/main/java/com/ams/aspect/TenantIsolationAspect.java`
+
+```java
+package com.ams.aspect;
+
+import com.ams.context.TenantContextHolder;
+import com.ams.exception.TenantSecurityException;
+import org.aspectj.lang.JoinPoint;
+import org.aspectj.lang.annotation.Aspect;
+import org.aspectj.lang.annotation.Before;
+import org.springframework.core.annotation.Order;
+import org.springframework.stereotype.Component;
+
+/**
+ * 租户隔离切面
+ * 所有 @TenantSensitive 注解的方法强制校验租户上下文
+ */
+@Aspect
+@Component
+@Order(1) // 高优先级，在其他切面之前执行
+public class TenantIsolationAspect {
+
+    @Before("@annotation(com.ams.annotation.TenantSensitive)")
+    public void validateTenantContext(JoinPoint joinPoint) {
+        Long tenantId = TenantContextHolder.getCurrentTenantId();
+        if (tenantId == null) {
+            throw new TenantSecurityException(
+                "TENANT_CONTEXT_REQUIRED",
+                "访问租户敏感接口必须提供有效 Token"
+            );
+        }
+    }
+}
+```
+
+**注解定义**:
+```java
+package com.ams.annotation;
+
+import java.lang.annotation.*;
+
+@Target(ElementType.METHOD)
+@Retention(RetentionPolicy.RUNTIME)
+@Documented
+public @interface TenantSensitive {
+    // 标记方法需要租户上下文校验
+}
+```
+
